# .env.example
# Copy this file to .env and fill in the values

# Required: The base URL of the backend API
# Must start with EXPO_PUBLIC_ so that Expo makes it available to the client application
EXPO_PUBLIC_BACKEND_URL=https://api.sovereigncivic.example.com

# for neo4j database connection
PORT=3000
NEO4J_URI=your_neo4j_uri
NEO4J_USERNAME=your_username
NEO4J_PASSWORD=your_password
WORKFLOW_WEBHOOK_URL=your_webhook_url